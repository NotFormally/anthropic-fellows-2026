# Required for benchmarking — at least one provider must be configured.
# Missing keys cause the corresponding model to be skipped at runtime
# (the harness logs a warning rather than failing the whole run).

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# Optional overrides — defaults shown in src/models.ts
# CLAUDE_MODEL=claude-opus-4-7-20251201
# OPENAI_MODEL=gpt-5
# GEMINI_MODEL=gemini-2.5-pro

# Optional: model used as the rubric judge (must be a strong reasoner).
# Defaults to the Claude model above.
# JUDGE_MODEL=claude-opus-4-7-20251201
